# ===========================================
# Athletix - Environment Configuration Template
# Copy this file to .env and update the values
# ===========================================

# Application
NODE_ENV=development
APP_NAME=Athletix

# Backend Server
PORT=5000
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/athletix

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
OTP_EXPIRY_MINUTES=10

# Email OTP delivery — choose ONE option below:

# Option A: Gmail SMTP (recommended — sends to any email address)
# 1. Enable 2-Step Verification on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Option B: Resend API (free tier at https://resend.com — 3,000 emails/month)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Athletix <onboarding@resend.dev>

# Option C: Generic SMTP (Brevo, Mailgun, etc.)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-login@email.com
# SMTP_PASS=your-smtp-key
# SMTP_FROM=your-login@email.com

# Football data — server-side only, never expose to frontend
# API-Football (api-sports.io) — comma-separated for key rotation
FOOTBALL_API_KEYS=your-api-football-key
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io
# football-data.org — comma-separated for key rotation (failover provider)
FOOTBALL_DATA_API_KEYS=your-football-data-key
FOOTBALL_DEFAULT_SEASON=2025

# Optional premium key — free test key "3" is used by default
THESPORTSDB_API_KEY=3

# Frontend
NEXT_PUBLIC_APP_NAME=Athletix
NEXT_PUBLIC_API_URL=http://localhost:5000/api
