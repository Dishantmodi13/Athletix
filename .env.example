# ===========================================
# Athletix - Environment Configuration Template
# Copy this file to .env and update the values
# ===========================================

# Application
NODE_ENV=development
APP_NAME=Athletix

# Backend Server
PORT=5000
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/athletix

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
OTP_EXPIRY_MINUTES=10

# Gmail OTP delivery (use App Password: https://myaccount.google.com/apppasswords)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Football data — server-side only, never expose to frontend
# API-Football (api-sports.io) — comma-separated for key rotation
FOOTBALL_API_KEYS=your-api-football-key
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io
# football-data.org — comma-separated for key rotation (failover provider)
FOOTBALL_DATA_API_KEYS=your-football-data-key
FOOTBALL_DEFAULT_SEASON=2025

# Frontend
NEXT_PUBLIC_APP_NAME=Athletix
NEXT_PUBLIC_API_URL=http://localhost:5000/api
